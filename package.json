{
  "name": "crm-project",
  "version": "1.0.0",
  "description": "O'quv markazi CRM — NestJS + React",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix client",
    "dev": "concurrently --names \"BACKEND,CLIENT\" --prefix-colors \"blue,green\" \"npm run dev:backend\" \"npm run dev:client\"",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix backend && npm run build --prefix client",
    "build:backend": "npm run build --prefix backend",
    "build:client": "npm run build --prefix client",
    "start:prod": "npm run start:prod --prefix backend",
    "seed:superadmin": "npm run seed:superadmin --prefix backend",
    "migration:run": "npm run migration:run --prefix backend",
    "migration:generate": "npm run migration:generate --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
