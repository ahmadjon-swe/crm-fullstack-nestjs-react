# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=crm_db

# ─── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_min_32_chars
JWT_ACCESS_EXPIRES=30m
JWT_REFRESH_EXPIRES=15d

# ─── Mail (Nodemailer) ──────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here
MAIL_FROM="CRM Panel <your_email@gmail.com>"

# ─── File Upload ────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ─── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── SuperAdmin (initial seed — run once then remove) ──────────────────────────
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=SuperAdmin@123
SUPERADMIN_NAME=Super Admin
